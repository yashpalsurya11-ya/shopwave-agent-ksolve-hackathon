LLM_PROVIDER=gemini

# Your Gemini API Key here
GEMINI_API_KEY=your_gemini_api_key_here

PORT=3000

# Max concurrent tickets in a single /resolve/all run (default: 20)
CONCURRENCY_LIMIT=20

# Max ReAct steps per ticket (default: 10)
MAX_REACT_STEPS=10

# Confidence threshold below which agent always escalates (default: 0.70)
CONFIDENCE_THRESHOLD=0.70
